// prisma/schema.prisma
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------- TENANT ----------
model Tenant {
  id        String    @id @default(uuid())
  name      String
  cnpj      String?   @unique
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  users     User[]    @relation("TenantUsers")
  patients  Patient[] @relation("TenantPatients")
}

// ---------- USER (RBAC) ----------
model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String
  role         String // ADMIN, DOCTOR, PATIENT
  tenantId     String
  tenant       Tenant   @relation("TenantUsers", fields: [tenantId], references: [id])
  patient      Patient? @relation("UserPatient")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

// ---------- PATIENT ----------
model Patient {
  id            String                @id @default(uuid())
  fullName      String
  birthDate     DateTime?
  phone         String?
  tenantId      String
  tenant        Tenant                @relation("TenantPatients", fields: [tenantId], references: [id])
  userId        String?               @unique
  user          User?                 @relation("UserPatient", fields: [userId], references: [id])
  bloodPressure BloodPressureRecord[] @relation("PatientBP")
  glucose       GlucoseRecord[]       @relation("PatientGlucose")
  createdAt     DateTime              @default(now())
  updatedAt     DateTime              @updatedAt
}

// ---------- BLOOD PRESSURE ----------
model BloodPressureRecord {
  id         String   @id @default(uuid())
  systolic   Int
  diastolic  Int
  pulse      Int? // bpm
  recordedAt DateTime @default(now())
  note       String?
  patientId  String
  patient    Patient  @relation("PatientBP", fields: [patientId], references: [id])
  createdAt  DateTime @default(now())
}

// ---------- GLUCOSE ----------
model GlucoseRecord {
  id         String   @id @default(uuid())
  valueMgDl  Float // mg/dL
  context    String // FASTING, PRE_MEAL, POST_MEAL, RANDOM
  recordedAt DateTime @default(now())
  note       String?
  patientId  String
  patient    Patient  @relation("PatientGlucose", fields: [patientId], references: [id])
  createdAt  DateTime @default(now())
}
